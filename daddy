			dragInput = nil
			dragStart = nil
			startCenter = nil
			moved = false
			if wasMoved then state.clampMobileButtonPosition() else toggleMacLibWindow() end
		end)

		task.defer(state.clampMobileButtonPosition)
		task.defer(state.syncMobileButtonLayer)
		task.defer(state.refreshMobileButtonVisibility)
