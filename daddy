-- ==================== LINGER SYSTEM ====================
local lingerState = {
	active = false,
	endTime = 0,
	lastValidTarget = nil,
	lastValidTargetPos = nil,
	lastValidGun = nil
}

-- Pre-declare variables used globally
local rng = Random.new()

local function startLinger(target, targetPos, gun)
	if not target or not targetPos or not gun then return end
	lingerState.active = true
	lingerState.lastValidTarget = target
	lingerState.lastValidTargetPos = targetPos
	lingerState.lastValidGun = gun
	lingerState.endTime = os.clock() + rng:NextNumber(0.05, 1.0)
end

local function stopLinger()
	lingerState.active = false
	lingerState.lastValidTarget = nil
	lingerState.lastValidTargetPos = nil
	lingerState.lastValidGun = nil
	lingerState.endTime = 0
end

local function isLingering()
	return lingerState.active and os.clock() < lingerState.endTime
end

