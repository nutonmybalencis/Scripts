local function findCastRay()
    -- Try filtergc first (old executors)
    if filtergc then
        local f = filtergc("function", {Name = "castRay"}, true)
        if f then return f end
    end
    
    -- Alternative: scan for the function by name/signature (more universal)
    for _, v in ipairs(getgc(true)) do
        if typeof(v) == "function" then
