-- ==================== WHITELIST SYSTEM (ENHANCED) ====================
local whitelist = {} -- {[UserId] = {name = string, displayName = string}, [UsernameLower] = true}
local whitelistEnabled = false
local whitelistMode = "both" -- "userId" or "username" or "both"
local whitelistPlayerList = {} -- Active player references for UI
local whitelistConnections = {}

local function normalizeUsername(name)
	return tostring(name or ""):lower():gsub("%s+", "")
end

local function isWhitelisted(player)
	if not whitelistEnabled or not player then
		return false
	end
	if whitelistMode == "userId" or whitelistMode == "both" then
		if whitelist[player.UserId] then
			return true
		end
	end
	if whitelistMode == "username" or whitelistMode == "both" then
		local normalized = normalizeUsername(player.Name)
		if whitelist[normalized] then
			return true
		end
		local displayNormalized = normalizeUsername(player.DisplayName)
		if whitelist[displayNormalized] then
			return true
		end
	end
	return false
end

-- Enhanced add that stores player info
local function addToWhitelist(identifier, playerInfo)
	local id = tonumber(identifier)
	if id then
		whitelist[id] = playerInfo or true
		return "userId", id
	end
	local normalized = normalizeUsername(identifier)
	if normalized ~= "" then
		whitelist[normalized] = playerInfo or true
		return "username", normalized
	end
	return nil, nil
end

local function removeFromWhitelist(identifier)
	local id = tonumber(identifier)
	if id and whitelist[id] then
		whitelist[id] = nil
		return true
	end
	local normalized = normalizeUsername(identifier)
	if normalized ~= "" and whitelist[normalized] then
		whitelist[normalized] = nil
		return true
	end
	return false
end

local function clearWhitelist()
	whitelist = {}
end

-- Get list with player names for display
local function getWhitelistList()
	local list = {}
	for key, info in pairs(whitelist) do
		local display = tostring(key)
		if typeof(info) == "table" and info.name then
			display = info.name .. " (" .. key .. ")"
		end
		table.insert(list, display)
	end
	table.sort(list)
	return list
end

-- Get raw entries for saving
local function getWhitelistSaveData()
	local list = {}
	for key, info in pairs(whitelist) do
		table.insert(list, {
			key = tostring(key),
			name = (typeof(info) == "table" and info.name) or nil,
			displayName = (typeof(info) == "table" and info.displayName) or nil
		})
	end
	return list
end

-- ==================== PLAYER LIST TRACKING ====================
local function updatePlayerList()
	whitelistPlayerList = {}
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			table.insert(whitelistPlayerList, player)
		end
	end
	-- Sort by name
	table.sort(whitelistPlayerList, function(a, b)
		return a.Name:lower() < b.Name:lower()
	end)
end

local function getPlayerListOptions()
	local options = {}
	for _, player in ipairs(whitelistPlayerList) do
		local isWl = isWhitelisted(player)
		local marker = isWl and " [✓]" or ""
		table.insert(options, player.Name .. " (" .. player.DisplayName .. ")" .. marker)
	end
	return options
end

local function getPlayerFromOption(optionText)
	local name = tostring(optionText):match("^([^%(]+)")
	if name then
		name = name:gsub("%s+$", "")
		for _, player in ipairs(whitelistPlayerList) do
			if player.Name == name then
				return player
			end
		end
	end
	return nil
end

-- Setup player tracking
local function setupPlayerTracking()
	-- Clear old connections
	for _, conn in ipairs(whitelistConnections) do
		conn:Disconnect()
	end
	whitelistConnections = {}
	
	-- Track all current players
	updatePlayerList()
	
	-- Update list when players join/leave
	table.insert(whitelistConnections, Players.PlayerAdded:Connect(function()
		task.defer(updatePlayerList)
		if uiElements.WhitelistPlayerDropdown then
			task.defer(refreshWhitelistPlayerList)
		end
	end))
	
	table.insert(whitelistConnections, Players.PlayerRemoving:Connect(function()
		task.defer(updatePlayerList)
		if uiElements.WhitelistPlayerDropdown then
			task.defer(refreshWhitelistPlayerList)
		end
	end))
end

-- ==================== SAVE/LOAD (PERSISTENT) ====================
local function saveWhitelist()
	if not isfolder then return end
	if not isfolder(configFolder) then
		makefolder(configFolder)
	end
	
	-- Build persistent data with player names
	local saveData = {
		enabled = whitelistEnabled,
		mode = whitelistMode,
		list = getWhitelistSaveData()
	}
	
	local data = game:GetService("HttpService"):JSONEncode(saveData)
	writefile(configFolder .. "/whitelist.json", data)
end

local function loadWhitelist()
	if not isfile then return end
	local path = configFolder .. "/whitelist.json"
	if not isfile(path) then return end
	
	local success, data = pcall(function()
		return game:GetService("HttpService"):JSONDecode(readfile(path))
	end)
	
	if not success or not data then return end
	
	whitelistEnabled = data.enabled or false
	whitelistMode = data.mode or "userId"
	clearWhitelist()
	
	-- Restore entries - try to resolve UserIds to current names
	for _, entry in ipairs(data.list or {}) do
		local key = entry.key
		local playerInfo = nil
		if entry.name then
			playerInfo = {name = entry.name, displayName = entry.displayName}
		end
		
		-- If it's a UserId, try to find current player with that ID
		local id = tonumber(key)
		if id then
			whitelist[id] = playerInfo or true
		else
			-- It's a username
			whitelist[key:lower()] = playerInfo or true
		end
	end
end

