local function refreshWhitelistPlayerList()
	if not uiElements.WhitelistPlayerDropdown then return end
	
	updatePlayerList()
	local options = getPlayerListOptions()
	
	if uiElements.WhitelistPlayerDropdown.ClearOptions then
		uiElements.WhitelistPlayerDropdown:ClearOptions()
	end
	if uiElements.WhitelistPlayerDropdown.InsertOptions then
		uiElements.WhitelistPlayerDropdown:InsertOptions(options)
	end
end

local function addSelectedPlayerToWhitelist(optionText)
	local player = getPlayerFromOption(optionText)
	if not player then
		Window:Notify({
			Title = "Whitelist",
			Description = "Could not find player!",
			Lifetime = 3
		})
		return false
	end
	
	-- Add both UserId and username for maximum persistence
	local info = {name = player.Name, displayName = player.DisplayName}
	addToWhitelist(tostring(player.UserId), info)
	addToWhitelist(player.Name, info)
	saveWhitelist()
	
	Window:Notify({
		Title = "Whitelist",
		Description = "Added " .. player.Name .. " to whitelist",
		Lifetime = 3
	})
	
	-- Refresh the list to show checkmark
	task.defer(refreshWhitelistPlayerList)
	return true
end

local function removeSelectedPlayerFromWhitelist(optionText)
	local player = getPlayerFromOption(optionText)
	if not player then
		Window:Notify({
			Title = "Whitelist",
			Description = "Could not find player!",
			Lifetime = 3
		})
		return false
	end
	
	removeFromWhitelist(tostring(player.UserId))
	removeFromWhitelist(player.Name)
	saveWhitelist()
	
	Window:Notify({
		Title = "Whitelist",
		Description = "Removed " .. player.Name .. " from whitelist",
		Lifetime = 3
	})
	
	task.defer(refreshWhitelistPlayerList)
	return true
end

